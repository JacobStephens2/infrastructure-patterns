{"title": "Server \u2014 Host", "uid": "host-overview", "tags": ["fleet"], "schemaVersion": 39, "version": 2, "refresh": "30s", "time": {"from": "now-6h", "to": "now"}, "timezone": "browser", "templating": {"list": []}, "annotations": {"list": []}, "panels": [{"id": 1, "title": "CPU busy %", "type": "stat", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))*100)", "datasource": {"type": "prometheus", "uid": "prometheus"}}], "fieldConfig": {"defaults": {"unit": "percent"}}, "options": {}}, {"id": 2, "title": "Memory used %", "type": "stat", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "(1 - node_memory_MemAvailable_bytes/node_memory_MemTotal_bytes)*100", "datasource": {"type": "prometheus", "uid": "prometheus"}}], "fieldConfig": {"defaults": {"unit": "percent"}}, "options": {}}, {"id": 3, "title": "Root disk used %", "type": "stat", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "100*(1 - node_filesystem_avail_bytes{mountpoint=\"/\"}/node_filesystem_size_bytes{mountpoint=\"/\"})", "datasource": {"type": "prometheus", "uid": "prometheus"}}], "fieldConfig": {"defaults": {"unit": "percent"}}, "options": {}}, {"id": 4, "title": "Volume (/dev/sda) used %", "type": "stat", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "100*(1 - max(node_filesystem_avail_bytes{device=\"/dev/sda\"})/max(node_filesystem_size_bytes{device=\"/dev/sda\"}))", "datasource": {"type": "prometheus", "uid": "prometheus"}}], "fieldConfig": {"defaults": {"unit": "percent"}}, "options": {}}, {"id": 5, "title": "CPU busy % (history)", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "targets": [{"refId": "A", "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))*100)", "datasource": {"type": "prometheus", "uid": "prometheus"}}], "fieldConfig": {"defaults": {"unit": "percent"}}, "options": {}}, {"id": 6, "title": "Load average", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "targets": [{"refId": "A", "expr": "node_load1", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "1m"}, {"refId": "B", "expr": "node_load5", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "5m"}, {"refId": "C", "expr": "node_load15", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "15m"}], "fieldConfig": {"defaults": {}}, "options": {}}, {"id": 7, "title": "Memory used", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8}, "targets": [{"refId": "A", "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "used"}, {"refId": "B", "expr": "node_memory_MemTotal_bytes", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "total"}], "fieldConfig": {"defaults": {"unit": "bytes"}}, "options": {}}, {"id": 8, "title": "Disk used % by device", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8}, "targets": [{"refId": "A", "expr": "max by(device)(100*(1 - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs\"}/node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs\"}))", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "{{device}}"}], "fieldConfig": {"defaults": {"unit": "percent"}}, "options": {}}, {"id": 9, "title": "Network throughput", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8}, "targets": [{"refId": "A", "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "rx {{device}}"}, {"refId": "B", "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])", "datasource": {"type": "prometheus", "uid": "prometheus"}, "legendFormat": "tx {{device}}"}], "fieldConfig": {"defaults": {"unit": "Bps"}}, "options": {}}]}